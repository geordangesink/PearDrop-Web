{
  "name": "pear-drops-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "prettier --check . && npm run lint:js",
    "lint:js": "npm run lint:js:browser && npm run lint:js:node && npm run lint:js:test",
    "lint:js:fix": "npm run lint:js:browser:fix && npm run lint:js:node:fix && npm run lint:js:test:fix",
    "lint:js:browser": "lunte --env=browser --global=WebSocket --global=RTCPeerConnection --global=Blob --global=CompressionStream src/**/*.js src/*.js",
    "lint:js:browser:fix": "lunte --env=browser --fix --global=WebSocket --global=RTCPeerConnection --global=Blob --global=CompressionStream src/**/*.js src/*.js",
    "lint:js:node": "lunte --env=node relay/**/*.js vite.config.js",
    "lint:js:node:fix": "lunte --env=node --fix relay/**/*.js vite.config.js",
    "lint:js:test": "lunte --env=node --global=document --global=window --global=location --global=HTMLElement test/*.test.js test/*.e2e.test.mjs",
    "lint:js:test:fix": "lunte --env=node --fix --global=document --global=window --global=location --global=HTMLElement test/*.test.js test/*.e2e.test.mjs",
    "format": "prettier --write . && npm run lint:js:fix",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "relay": "node relay/server.js",
    "test": "npm run test:node && npm run test:e2e",
    "test:node": "node --test test/*.test.js",
    "test:e2e": "node --test --test-force-exit test/*.e2e.test.mjs"
  },
  "dependencies": {
    "@hyperswarm/dht-relay": "^0.4.3",
    "b4a": "^1.8.0",
    "corestore": "^7.9.2",
    "hyperdht": "^6.19.1",
    "hyperdrive": "^13.0.1",
    "sodium-javascript": "^0.8.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@peardrops/native-shared": "file:../native-shared",
    "hyperdht": "^6.19.1",
    "hyperswarm": "^4.17.0",
    "lunte": "^1.6.0",
    "playwright": "^1.55.0",
    "prettier": "^3.8.1",
    "prettier-config-holepunch": "^2.0.0",
    "vite": "^7.1.10"
  },
  "license": "Apache-2.0"
}
